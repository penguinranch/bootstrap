# Project Environment Variables
# Copy to .env and fill in your details

# Git Configuration (for signing commits within container)
GIT_NAME=
GIT_EMAIL=

# Gemini CLI API Key (for AI tooling inside the Devcontainer)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# GitHub Token (for GitHub CLI and AI agents interacting with PRs/Issues)
# Generate a Fine-grained PAT: https://github.com/settings/tokens?type=beta
# Required scopes: 'Pull Requests: Read-only' and 'Contents: Read-only'
GITHUB_TOKEN=

# Add project specific secrets below

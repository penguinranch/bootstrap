# Project Environment Variables
# Copy to .env and fill in your details

# Git Configuration (for signing commits within container)
GIT_NAME=
GIT_EMAIL=
SSH_PUBLIC_KEY=

# Gemini CLI API Key (for AI tooling inside the Devcontainer)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic API Key (for the Claude CLI inside the Devcontainer)
# Optional — you can also authenticate interactively by running: claude
ANTHROPIC_API_KEY=

# GitHub Token (for GitHub CLI, the GitHub MCP server in .mcp.json, and AI
# agents interacting with PRs/Issues)
# Generate a Fine-grained PAT: https://github.com/settings/tokens?type=beta
# Optional — you can also authenticate interactively by running: gh auth login
GITHUB_TOKEN=

# Context7 API Key (for the Context7 MCP server in .mcp.json — up-to-date
# library docs for AI agents)
# Optional — works without a key at lower rate limits.
# Get a free key at: https://context7.com/dashboard
CONTEXT7_API_KEY=

# Add project specific secrets below

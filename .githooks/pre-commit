#!/bin/bash
# Pre-commit hook: runs lint checks before allowing a commit.
# Installed automatically by `make setup`.

# Skip quietly if make or the lint target is unavailable (stack not configured yet)
if ! command -v make >/dev/null 2>&1 || ! make -n lint >/dev/null 2>&1; then
  echo "⚠️  'make lint' not available yet. Skipping pre-commit lint."
  exit 0
fi

if make lint; then
  echo "✅ Lint checks passed."
else
  echo "❌ Lint failed. Fix the errors above (or run 'make format')."
  echo "   To bypass in an emergency: git commit --no-verify"
  exit 1
fi

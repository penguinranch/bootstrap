# Environment
.env
.env.*
!.env.example

# Node
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# Python
# Generic names (env, lib, bin, var...) are anchored to the repo root —
# unanchored they would swallow real source directories in other stacks
# (a Rails bin/, a Go lib/) at any depth.
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
/env/
develop-eggs/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
/var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/

# Go
/bin/
/obj/
*.exe
*.exe~
*.dll
*.dylib
*.test
*.out

# Mac
.DS_Store

# IDEs
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp

# Bootstrap sentinel
.devcontainer/.bootstrapped

# Testing
.tmp-test/
